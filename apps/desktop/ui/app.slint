// Relic desktop shell — Phase 2 system/game browser skeleton (ADR-002, Slint).
// Real data from relic-core via Engine, wired up in src/main.rs. Still missing
// from PLAN.md Phase 2 scope: detail page, first-run wizard, gamepad input.
// Colors come from the `Palette` global, populated in main.rs via
// relic-themes' resolved default theme (PLAN.md section 6 layer 1).

import { Button, LineEdit, ListView, StandardListView } from "std-widgets.slint";

export struct GameItem {
    id: int,
    name: string,
    favorite: bool,
}

export struct StatRow {
    name: string,
    subtitle: string,
}

export struct PendingMatchRow {
    game-id: int,
    name: string,
    provider-id: string,
    confidence: string,
    external-id: string,
}

// Design tokens (PLAN.md section 6 layer 1), populated from relic-themes'
// resolved default theme in main.rs. Defaults here match the prior
// hardcoded look so the UI degrades sanely if Rust never sets them.
export global Palette {
    in property <color> bg: #1a1a1a;
    in property <color> surface: #262626;
    in property <color> text: white;
    in property <color> text-dim: #cccccc;
    in property <color> accent: #e0c341;
    in property <color> favorite: #e0c341;
}

export component MainWindow inherits Window {
    title: "Relic";
    preferred-width: 900px;
    preferred-height: 600px;
    background: Palette.bg;

    in property <string> status-line;
    in property <[StandardListViewItem]> systems-model;
    in property <[GameItem]> games-model;
    in property <string> games-heading;
    in-out property <string> search-text;
    in property <string> emulator-status;
    in-out property <string> emulator-name-input;
    in-out property <string> emulator-exec-input;
    in-out property <string> emulator-args-input: "{rom}";
    in property <bool> show-stats: false;
    in property <[StatRow]> recent-model;
    in property <[StatRow]> most-played-model;
    in property <string> stats-summary;
    in property <bool> show-scraper: false;
    in property <[PendingMatchRow]> pending-matches-model;

    callback system-selected(int);
    callback search-edited(string);
    callback favorite-toggled(int);
    callback add-library-requested();
    callback game-launch-requested(int);
    callback browse-emulator-exec();
    callback save-launch-profile();
    callback stats-toggled();
    callback scraper-toggled();
    callback match-confirmed(int, string);

    VerticalLayout {
        padding: 12px;
        spacing: 8px;

        HorizontalLayout {
            spacing: 12px;
            alignment: space-between;

            Text {
                text: "Relic";
                font-size: 28px;
                font-weight: 700;
                color: Palette.text;
            }

            Button {
                text: "Add Folder…";
                clicked => {
                    add-library-requested();
                }
            }

            Button {
                text: "Stats";
                clicked => {
                    stats-toggled();
                }
            }

            Button {
                text: "Scraper";
                clicked => {
                    scraper-toggled();
                }
            }
        }

        if !show-stats && !show-scraper : HorizontalLayout {
            spacing: 12px;

            VerticalLayout {
                width: 260px;
                spacing: 4px;

                Text {
                    text: "Systems";
                    font-size: 16px;
                    color: Palette.text-dim;
                }

                StandardListView {
                    model: systems-model;
                    current-item-changed(index) => {
                        system-selected(index);
                    }
                }
            }

            VerticalLayout {
                spacing: 4px;

                Text {
                    text: games-heading;
                    font-size: 16px;
                    color: Palette.text-dim;
                }

                LineEdit {
                    placeholder-text: "Search games…";
                    text <=> search-text;
                    edited(text) => {
                        search-edited(text);
                    }
                }

                Text {
                    text: emulator-status;
                    color: Palette.accent;
                    font-size: 11px;
                    wrap: word-wrap;
                }

                HorizontalLayout {
                    spacing: 4px;

                    LineEdit {
                        placeholder-text: "Emulator name";
                        text <=> emulator-name-input;
                        width: 110px;
                    }

                    LineEdit {
                        placeholder-text: "Path to emulator executable";
                        text <=> emulator-exec-input;
                    }

                    Button {
                        text: "Browse…";
                        clicked => {
                            browse-emulator-exec();
                        }
                    }

                    LineEdit {
                        placeholder-text: "{rom}";
                        text <=> emulator-args-input;
                        width: 90px;
                    }

                    Button {
                        text: "Save";
                        clicked => {
                            save-launch-profile();
                        }
                    }
                }

                ListView {
                    for game in games-model: Rectangle {
                        height: 26px;

                        row-area := TouchArea {
                            double-clicked => {
                                game-launch-requested(game.id);
                            }
                        }

                        HorizontalLayout {
                            padding-left: 4px;
                            spacing: 6px;
                            alignment: start;

                            star-area := TouchArea {
                                width: 16px;
                                clicked => {
                                    favorite-toggled(game.id);
                                }

                                Text {
                                    text: game.favorite ? "★" : "☆";
                                    color: Palette.favorite;
                                    font-size: 13px;
                                }
                            }

                            Text {
                                text: game.name;
                                color: Palette.text;
                                font-size: 13px;
                                vertical-alignment: center;
                            }
                        }
                    }
                }
            }
        }

        if show-stats : VerticalLayout {
            spacing: 8px;

            Text {
                text: stats-summary;
                color: Palette.text;
                font-size: 14px;
            }

            Text {
                text: "Recently Played";
                font-size: 16px;
                color: Palette.text-dim;
            }

            ListView {
                height: 220px;
                for row in recent-model: Rectangle {
                    height: 34px;

                    VerticalLayout {
                        padding-left: 4px;
                        alignment: center;

                        Text {
                            text: row.name;
                            color: Palette.text;
                            font-size: 13px;
                        }

                        Text {
                            text: row.subtitle;
                            color: Palette.text-dim;
                            font-size: 11px;
                        }
                    }
                }
            }

            Text {
                text: "Most Played";
                font-size: 16px;
                color: Palette.text-dim;
            }

            ListView {
                height: 220px;
                for row in most-played-model: Rectangle {
                    height: 34px;

                    VerticalLayout {
                        padding-left: 4px;
                        alignment: center;

                        Text {
                            text: row.name;
                            color: Palette.text;
                            font-size: 13px;
                        }

                        Text {
                            text: row.subtitle;
                            color: Palette.text-dim;
                            font-size: 11px;
                        }
                    }
                }
            }
        }

        if show-scraper : VerticalLayout {
            spacing: 8px;

            Text {
                text: "Pending scraper matches";
                font-size: 16px;
                color: Palette.text-dim;
            }

            ListView {
                for row in pending-matches-model: Rectangle {
                    height: 40px;

                    HorizontalLayout {
                        padding-left: 4px;
                        spacing: 8px;
                        alignment: space-between;

                        VerticalLayout {
                            alignment: center;

                            Text {
                                text: row.name;
                                color: Palette.text;
                                font-size: 13px;
                            }

                            Text {
                                text: row.provider-id + " — " + row.confidence + " confidence — #" + row.external-id;
                                color: Palette.text-dim;
                                font-size: 11px;
                            }
                        }

                        Button {
                            text: "Confirm";
                            clicked => {
                                match-confirmed(row.game-id, row.provider-id);
                            }
                        }
                    }
                }
            }
        }

        Text {
            text: status-line;
            color: Palette.text-dim;
            font-size: 12px;
        }
    }
}
