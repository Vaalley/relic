// Relic desktop shell — Phase 2 system/game browser skeleton (ADR-002, Slint).
// Real data from relic-core via Engine, wired up in src/main.rs. Still missing
// from PLAN.md Phase 2 scope: detail page, search, favorites toggle, launch,
// first-run wizard, gamepad input, design-token theming.

import { Button, LineEdit, ListView, StandardListView } from "std-widgets.slint";

export struct GameItem {
    id: int,
    name: string,
    favorite: bool,
}

export component MainWindow inherits Window {
    title: "Relic";
    preferred-width: 900px;
    preferred-height: 600px;
    background: #1a1a1a;

    in property <string> status-line;
    in property <[StandardListViewItem]> systems-model;
    in property <[GameItem]> games-model;
    in property <string> games-heading;
    in-out property <string> search-text;
    in property <string> emulator-status;
    in-out property <string> emulator-name-input;
    in-out property <string> emulator-exec-input;
    in-out property <string> emulator-args-input: "{rom}";

    callback system-selected(int);
    callback search-edited(string);
    callback favorite-toggled(int);
    callback add-library-requested();
    callback game-launch-requested(int);
    callback browse-emulator-exec();
    callback save-launch-profile();

    VerticalLayout {
        padding: 12px;
        spacing: 8px;

        HorizontalLayout {
            spacing: 12px;
            alignment: space-between;

            Text {
                text: "Relic";
                font-size: 28px;
                font-weight: 700;
                color: white;
            }

            Button {
                text: "Add Folder…";
                clicked => {
                    add-library-requested();
                }
            }
        }

        HorizontalLayout {
            spacing: 12px;

            VerticalLayout {
                width: 260px;
                spacing: 4px;

                Text {
                    text: "Systems";
                    font-size: 16px;
                    color: #cccccc;
                }

                StandardListView {
                    model: systems-model;
                    current-item-changed(index) => {
                        system-selected(index);
                    }
                }
            }

            VerticalLayout {
                spacing: 4px;

                Text {
                    text: games-heading;
                    font-size: 16px;
                    color: #cccccc;
                }

                LineEdit {
                    placeholder-text: "Search games…";
                    text <=> search-text;
                    edited(text) => {
                        search-edited(text);
                    }
                }

                Text {
                    text: emulator-status;
                    color: #e0c341;
                    font-size: 11px;
                    wrap: word-wrap;
                }

                HorizontalLayout {
                    spacing: 4px;

                    LineEdit {
                        placeholder-text: "Emulator name";
                        text <=> emulator-name-input;
                        width: 110px;
                    }

                    LineEdit {
                        placeholder-text: "Path to emulator executable";
                        text <=> emulator-exec-input;
                    }

                    Button {
                        text: "Browse…";
                        clicked => {
                            browse-emulator-exec();
                        }
                    }

                    LineEdit {
                        placeholder-text: "{rom}";
                        text <=> emulator-args-input;
                        width: 90px;
                    }

                    Button {
                        text: "Save";
                        clicked => {
                            save-launch-profile();
                        }
                    }
                }

                ListView {
                    for game in games-model: Rectangle {
                        height: 26px;

                        row-area := TouchArea {
                            double-clicked => {
                                game-launch-requested(game.id);
                            }
                        }

                        HorizontalLayout {
                            padding-left: 4px;
                            spacing: 6px;
                            alignment: start;

                            star-area := TouchArea {
                                width: 16px;
                                clicked => {
                                    favorite-toggled(game.id);
                                }

                                Text {
                                    text: game.favorite ? "★" : "☆";
                                    color: #e0c341;
                                    font-size: 13px;
                                }
                            }

                            Text {
                                text: game.name;
                                color: white;
                                font-size: 13px;
                                vertical-alignment: center;
                            }
                        }
                    }
                }
            }
        }

        Text {
            text: status-line;
            color: #999999;
            font-size: 12px;
        }
    }
}
