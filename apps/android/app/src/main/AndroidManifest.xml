<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Alpha shortcut (ES-DE precedent for sideloaded launchers): all-files
         access keeps the path-based core engine working. SAF/content-URI
         translation per docs/android-intents.md replaces broad reads later. -->
    <uses-permission android:name="android.permission.MANAGE_EXTERNAL_STORAGE" />
    <uses-permission
        android:name="android.permission.READ_EXTERNAL_STORAGE"
        android:maxSdkVersion="32" />

    <!-- Package visibility for explicit emulator launch intents. -->
    <queries>
        <package android:name="com.retroarch" />
        <package android:name="com.retroarch.aarch64" />
        <package android:name="org.dolphinemu.dolphinemu" />
        <package android:name="org.dolphinemu.mmjr" />
        <package android:name="com.github.stenzek.duckstation" />
        <package android:name="org.ppsspp.ppsspp" />
        <package android:name="org.ppsspp.ppssppgold" />
        <package android:name="org.ppsspp.ppsspplegacy" />
        <package android:name="me.magnum.melonds" />
        <package android:name="xyz.aethersx2.android" />
        <package android:name="io.github.lime3ds.android" />
        <package android:name="org.mupen64plusae.v3.fzurita" />
        <package android:name="org.devmiyax.yabasanshioro2.pro" />
    </queries>

    <application
        android:label="Relic"
        android:theme="@android:style/Theme.Material.NoActionBar"
        android:supportsRtl="true">
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTask">
            <!-- HOME + DEFAULT categories make Relic selectable as the device's
                 default Home app (Phase 3 exit criterion, PLAN.md §9). -->
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
                <category android:name="android.intent.category.HOME" />
                <category android:name="android.intent.category.DEFAULT" />
            </intent-filter>
        </activity>

        <!-- Mints a single-file content:// URI to hand one ROM to an
             external emulator (docs/android-intents.md §5 step 8), scoped by
             FLAG_GRANT_READ_URI_PERMISSION to that one file — not exported,
             not a broader grant of Relic's library. -->
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>
    </application>
</manifest>
